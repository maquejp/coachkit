{
  "$schema": "https://raw.githubusercontent.com/DavidAnson/markdownlint-cli2/main/schema/markdownlint-cli2-config.json",
  "config": {
    "default": true,
    "MD013": {
      "line_length": 400,
      "tables": false,
      "code_blocks": false,
      "headings": false
    },
    "MD060": false,
    "MD033": false,
    "MD024": {
      "allow_different_nesting": true
    }
  }
}
