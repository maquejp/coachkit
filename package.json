{
  "name": "coachkit",
  "private": true,
  "scripts": {
    "lint": "eslint application/frontend/",
    "lint:fix": "eslint application/frontend/ --fix",
    "lint:markdown": "markdownlint-cli2 docs/**/*.md",
    "lint:markdown:fix": "markdownlint-cli2 --fix docs/**/*.md",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "docs/**/*.md": [
      "markdownlint-cli2 --fix"
    ],
    "*.{js,jsx,ts,tsx,json,css,php}": [
      "prettier --write --ignore-unknown"
    ],
    "application/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write --ignore-unknown"
    ],
    "application/**/*.{json,css,php}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.59.3"
  }
}
